# Server
PORT=3001
NODE_ENV=production

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=replace-with-a-strong-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=7

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=https://your-app.vercel.app

# OTP
OTP_EXPIRES_MINUTES=10
OTP_MAX_ATTEMPTS=3
# Never set to true in production
OTP_DEV_EXPOSE=false

# Database — use /data/splitease.db on Railway with persistent volume
DB_PATH=/data/splitease.db

# Invite links — set to your Vercel frontend URL
INVITE_BASE_URL=https://your-app.vercel.app/invite
INVITE_TOKEN_TTL_DAYS=7

# Email — choose ONE provider
#
# Option 1: Gmail SMTP
#   1. Enable 2FA on https://myaccount.google.com/security
#   2. Create App Password at https://myaccount.google.com/apppasswords
SMTP_USER=you@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
#
# Option 2: Resend (https://resend.com, free 3000 emails/month)
# RESEND_API_KEY=re_xxxxxxxxxxxx
# EMAIL_FROM=SplitEase <noreply@yourdomain.com>
