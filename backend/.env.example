# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production           # "development" locally, "production" in deployment

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# ⚠️  NEVER use the placeholder in production — the server warns but won't exit
JWT_SECRET=CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no wildcards)
CORS_ORIGINS=https://your-app.vercel.app

# ── OTP ───────────────────────────────────────────────────────────────────────
OTP_EXPIRES_MINUTES=10
OTP_MAX_ATTEMPTS=3
# ⚠️  MUST be "false" (or absent) in production — exposes OTP codes in API responses
OTP_DEV_EXPOSE=false

# ── Database ──────────────────────────────────────────────────────────────────
# Use a persistent volume path in production (e.g. Railway /data mount)
DB_PATH=/data/splitease.db

# ── Invite links ──────────────────────────────────────────────────────────────
INVITE_BASE_URL=https://your-app.vercel.app/invite
INVITE_TOKEN_TTL_DAYS=7

# ── Email — choose ONE provider ───────────────────────────────────────────────

# Option 1: Resend API (recommended — free tier: 3 000 emails/month)
#   Sign up at https://resend.com, verify your domain, paste key below.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# EMAIL_FROM=SplitEase <noreply@yourdomain.com>

# Option 2: Gmail SMTP (personal/dev use — avoid in high-volume production)
#   1. Enable 2-Step Verification at https://myaccount.google.com/security
#   2. Create an App Password at https://myaccount.google.com/apppasswords
#   3. Paste the 16-character app password (spaces are acceptable)
# SMTP_USER=you@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx
