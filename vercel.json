{
  "installCommand": "pnpm install",
  "buildCommand": "pnpm --filter splitease-frontend build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/[...slug].ts": {
      "maxDuration": 30
    }
  },
  "routes": [
    { "handle": "filesystem" },
    { "src": "/api/(.*)", "dest": "/api/[...slug]" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
